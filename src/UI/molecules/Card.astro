---
interface Props {
	title: string;
	description: string;
	image: {
		src: string;
		alt?: string;
	};
}

const { title, description, image } = Astro.props;
---

<article
	class="group relative flex h-[420px] flex-col justify-end overflow-hidden rounded-2xl bg-[#171719] transition-all duration-500 ease-out hover:-translate-y-1 hover:shadow-xl hover:shadow-black/20"
	style={`background-image: url(${image.src}); background-size: cover; background-position: center;`}
	aria-label={`${title}: ${description}`}
>
	<!-- Overlay gradient for readability -->
	<div class="absolute inset-0 bg-gradient-to-t from-[#0d0d0f] via-[#0d0d0f]/40 to-transparent" aria-hidden="true"></div>
	<!-- Diagonal accent -->
	<div class="absolute -right-12 -top-12 h-32 w-32 rotate-45 bg-[var(--tangerine)]/90 opacity-80 transition-all duration-500 group-hover:scale-150 group-hover:opacity-100" aria-hidden="true"></div>
	<!-- Bottom edge highlight -->
	<div class="absolute bottom-0 left-0 h-px w-0 bg-[var(--tangerine)] transition-all duration-500 group-hover:w-full" aria-hidden="true"></div>

	<div class="relative z-10 px-5 pb-5 pt-16">
		<span class="mb-1.5 block text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--tangerine)] opacity-90">Recurso</span>
		<h3 class="line-clamp-2 text-xl font-bold tracking-tight text-[var(--white)] transition-colors duration-300 group-hover:text-[var(--tangerine)] md:text-2xl">
			{title}
		</h3>
		<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-white/70">{description}</p>
		<span class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-[var(--tangerine)] opacity-0 transition-all duration-300 group-hover:opacity-100">
			Abrir
			<svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
			</svg>
		</span>
	</div>
</article>
