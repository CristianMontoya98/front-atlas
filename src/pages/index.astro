---
import Layout from '../layouts/Layout.astro';
import Header from '../UI/molecules/Header.astro';
import Card from '../UI/molecules/Card.astro';
import frontResources from '../utils/front-resources.json';
import '../styles/global.css';

const { resources } = frontResources;
---

<Layout>
	<Header />
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{resources.map((resource) => (
				<li>
					<a href={resource.url} target="_blank" rel="noopener noreferrer" class="block">
						<Card
							title={resource.name}
							description={resource.description}
							image={{
								src: `https://picsum.photos/seed/${resource.id}/400/225`,
								alt: resource.name,
							}}
						/>
					</a>
				</li>
			))}
		</ul>
	</section>
</Layout>
